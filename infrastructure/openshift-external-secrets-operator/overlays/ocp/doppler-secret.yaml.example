# EXAMPLE ONLY — create this Secret out-of-band (never commit a real token).
#   oc create secret generic doppler-token-auth-api \
#     --namespace external-secrets \
#     --from-literal=dopplerToken='dp.st....'
apiVersion: v1
kind: Secret
metadata:
  name: doppler-token-auth-api
  namespace: external-secrets
type: Opaque
stringData:
  dopplerToken: "REPLACE_ME"
